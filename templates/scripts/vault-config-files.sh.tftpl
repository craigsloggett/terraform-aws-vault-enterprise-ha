# vault-config-files.sh — Configuration file writers and post-init setup.
#
# This file is rendered by Terraform templatefile() to embed configuration
# content. Functions here write config files to disk and configure Vault
# features that require inline configuration data.

write_vault_systemd_unit() {
  log_info "Writing Vault systemd unit"

  cat >/etc/systemd/system/vault.service <<EOF
${config_vault_service}
EOF

  mkdir -p /etc/systemd/system/vault.service.d
  cat >/etc/systemd/system/vault.service.d/override.conf <<'EOF'
${config_vault_service_override}
EOF
  chmod 0600 /etc/systemd/system/vault.service.d/override.conf
}

get_license() {
  region="$${1}"
  vault_license_secret_arn="$${2}"
  fetch_secret "$${region}" "$${vault_license_secret_arn}"
}

get_bootstrap_root_ca() {
  region="$${1}"
  bootstrap_tls_ca_cert_secret_arn="$${2}"
  fetch_secret "$${region}" "$${bootstrap_tls_ca_cert_secret_arn}"
}

get_bootstrap_tls_cert() {
  region="$${1}"
  bootstrap_tls_server_cert_secret_arn="$${2}"
  fetch_secret "$${region}" "$${bootstrap_tls_server_cert_secret_arn}"
}

get_bootstrap_tls_key() {
  region="$${1}"
  bootstrap_tls_server_key_secret_arn="$${2}"
  fetch_secret "$${region}" "$${bootstrap_tls_server_key_secret_arn}"
}

write_tls_materials() {
  vault_license="$${1}"
  ca_cert="$${2}"
  server_cert="$${3}"
  server_key="$${4}"
  vault_license_file="$${5}"
  vault_tls_ca_file="$${6}"
  vault_tls_cert_file="$${7}"
  vault_tls_key_file="$${8}"

  log_info "Writing the Vault license"
  printf '%s\n' "$${vault_license}" >"$${vault_license_file}"
  chown vault:vault "$${vault_license_file}"
  chmod 0640 "$${vault_license_file}"

  log_info "Writing bootstrap TLS certificates"
  printf '%s\n' "$${ca_cert}" >"$${vault_tls_ca_file}"
  printf '%s\n' "$${server_cert}" >"$${vault_tls_cert_file}"
  printf '%s\n' "$${server_key}" >"$${vault_tls_key_file}"

  chown vault:vault "$${vault_tls_ca_file}" "$${vault_tls_cert_file}" "$${vault_tls_key_file}"
  chmod 0640 "$${vault_tls_cert_file}" "$${vault_tls_key_file}"
  chmod 0644 "$${vault_tls_ca_file}"
}

write_vault_config() {
  vault_config_file="$${1}"
  private_ip="$${2}"
  instance_id="$${3}"
  availability_zone="$${4}"

  log_info "Writing Vault configuration (bind=$${private_ip})"

  cat >"$${vault_config_file}" <<EOF
${config_vault_hcl}
EOF

  chown vault:vault "$${vault_config_file}"
  chmod 0640 "$${vault_config_file}"
}

configure_autopilot() {
  vault_token="$${1}"
  vault_fqdn="$${2}"
  vault_tls_ca_file="$${3}"

  export VAULT_ADDR="https://127.0.0.1:8200"
  export VAULT_TLS_SERVER_NAME="$${vault_fqdn}"
  export VAULT_CACERT="$${vault_tls_ca_file}"
  export VAULT_TOKEN="$${vault_token}"

  log_info "Configuring Raft Autopilot"

  vault operator raft autopilot set-config \
    -cleanup-dead-servers=true \
    -dead-server-last-contact-threshold=10m \
    -min-quorum=${vault_minimum_quorum_size}

  log_info "Raft Autopilot configured"
}

configure_snapshots() {
  vault_token="$${1}"
  vault_fqdn="$${2}"
  vault_tls_ca_file="$${3}"
  vault_snapshot_config_file="$${4}"

  export VAULT_ADDR="https://127.0.0.1:8200"
  export VAULT_TLS_SERVER_NAME="$${vault_fqdn}"
  export VAULT_CACERT="$${vault_tls_ca_file}"
  export VAULT_TOKEN="$${vault_token}"

  log_info "Configuring automated Raft snapshots"

  cat >"$${vault_snapshot_config_file}" <<'EOF'
${config_snapshot_json}
EOF

  chown vault:vault "$${vault_snapshot_config_file}"
  chmod 0640 "$${vault_snapshot_config_file}"

  vault write sys/storage/raft/snapshot-auto/config/hourly \
    @"$${vault_snapshot_config_file}"

  log_info "Automated Raft snapshots configured"
}

setup_vault_agent() {
  vault_agent_config_file="$${1}"
  vault_agent_server_tls_template_file="$${2}"
  vault_agent_server_tls_template_command_file="$${3}"

  log_info "Setting up Vault Agent for PKI certificate rotation"

  cat >"$${vault_agent_config_file}" <<EOF
${config_agent_hcl}
EOF

  chown vault:vault "$${vault_agent_config_file}"
  chmod 0644 "$${vault_agent_config_file}"

  cat >"$${vault_agent_server_tls_template_file}" <<EOF
${config_vault_server_tls_ctmpl}
EOF
  chown vault:vault "$${vault_agent_server_tls_template_file}"
  chmod 0644 "$${vault_agent_server_tls_template_file}"

  cat >"$${vault_agent_server_tls_template_command_file}" <<EOF
${config_reload_vault_server_tls}
EOF
  chown root:root "$${vault_agent_server_tls_template_command_file}"
  chmod 0755 "$${vault_agent_server_tls_template_command_file}"

  cat >/etc/polkit-1/rules.d/10-vault-agent-reload.rules <<'EOF'
${config_vault_agent_reload_rules}
EOF

  cat >/etc/systemd/system/vault-agent.service <<EOF
${config_vault_agent_service}
EOF

  systemctl daemon-reload
  systemctl enable --now vault-agent

  log_info "Vault Agent started"
}
